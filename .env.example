# ── Aptos ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APTOS_API_KEY=
# Network: mainnet | testnet
NEXT_PUBLIC_APTOS_NETWORK=mainnet

# ── Shelby Protocol ────────────────────────────────────────────────────────────
# Network: shelbynet | testnet
NEXT_PUBLIC_SHELBY_NETWORK=shelbynet
# Override default RPC (optional)
NEXT_PUBLIC_SHELBY_RPC_URL=
# Override aggregator URL (optional)
NEXT_PUBLIC_SHELBY_AGGREGATOR_URL=

# ── App ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://shelbyhub.xyz
# Optional: analytics / error tracking
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=
